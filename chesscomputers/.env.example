# --- Firebase service account (get from Firebase Console → Project Settings → Service Accounts → Generate new private key) ---
FIREBASE_PROJECT_ID=evaluchess
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@evaluchess.iam.gserviceaccount.com
# IMPORTANT: keep literal \n in the private key. Wrap whole thing in quotes.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=https://evaluchess-default-rtdb.firebaseio.com

# --- Target deployment ---
API_BASE=https://evaluchess.com
